# psychopy-core.zip (built by web_backend/pyodide/build_archive.sh) is committed
# on purpose: restricted CI sandboxes (EdgeOne) can't run the pip/zip vendoring,
# so ship the prebuilt archive and let build.sh skip rebuilding it. Regenerate
# with `bash web_backend/pyodide/build_archive.sh` when upstream psychopy moves.
# Self-hosted pyodide runtime + numpy (generated by web_backend/pyodide/fetch_runtime.sh)
static/pyodide/runtime/
