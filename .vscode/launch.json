{
    "configurations": [
        {
            "name": "PsychopPy Studio (app)",
            "request": "launch",
            "cwd": "${workspaceFolder}/electron",
            "runtimeArgs": [
                "run",
                "electron:start"
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "PsychopPy Studio Builder (app)",
            "request": "launch",
            "cwd": "${workspaceFolder}/electron",
            "runtimeArgs": [
                "run",
                "electron:start",
                "--",
                "--builder"
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "PsychopPy Studio Coder (app)",
            "request": "launch",
            "cwd": "${workspaceFolder}/electron",
            "runtimeArgs": [
                "run",
                "electron:start",
                "--",
                "--coder"
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "PsychopPy Studio Runner (app)",
            "request": "launch",
            "cwd": "${workspaceFolder}/electron",
            "runtimeArgs": [
                "run",
                "electron:start",
                "--",
                "--runner"
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "PsychoPy Studio (browser)",
            "request": "launch",
            "runtimeArgs": [
                "run",
                "svelte:dev",
                "--",
                "--open"
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        }
    ]
}